# RichSinkhole — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# PostgreSQL password for Invidious
POSTGRES_PASSWORD=changeme_strong_password

# HMAC key for Invidious (generate with: openssl rand -hex 32)
INVIDIOUS_HMAC_KEY=changeme_generate_with_openssl_rand_hex_32

# Shared secret key for Invidious Companion (max 16 characters, generate with: openssl rand -hex 8)
INVIDIOUS_COMPANION_KEY=changeme12345678

# Host port for the nginx reverse proxy (auto-detected by setup.sh)
# Uses 8880 by default to avoid conflicts with common services on 80/8080
HTTP_PORT=8880

# Set to true to enable Invidious (YouTube frontend) + PostgreSQL
# When false, only the DNS sinkhole + dashboard are started
ENABLE_INVIDIOUS=false

# nginx config file to use (set automatically by setup.sh)
NGINX_CONFIG=nginx-standalone.conf

# Timezone (default: Asia/Manila)
TZ=Asia/Manila
